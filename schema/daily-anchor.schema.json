{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "urn:tyche:mirror:daily-anchor:0.1",
  "title": "MIRROR daily anchor payload",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "date",
    "created",
    "rollup_path",
    "rollup_sha256",
    "entry_count",
    "merkle_root",
    "previous_anchor_hash",
    "external_timestamp",
    "note"
  ],
  "properties": {
    "schema": {"const": "mirror.daily-anchor.v0.1"},
    "date": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
    "created": {"type": "string", "minLength": 1},
    "rollup_path": {
      "type": "string",
      "pattern": "^daily-roll-up/[0-9]{4}-[0-9]{2}-[0-9]{2}\\.json$"
    },
    "rollup_sha256": {"$ref": "#/definitions/sha256"},
    "entry_count": {"type": "integer", "minimum": 0},
    "merkle_root": {
      "anyOf": [
        {"$ref": "#/definitions/sha256"},
        {"type": "null"}
      ]
    },
    "previous_anchor_hash": {
      "anyOf": [
        {"$ref": "#/definitions/sha256"},
        {"type": "null"}
      ]
    },
    "external_timestamp": {"type": "null"},
    "note": {
      "type": "string",
      "pattern": "no external timestamping or regulated trust service"
    }
  },
  "definitions": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}
